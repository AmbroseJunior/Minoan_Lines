# ============================================================
# Minoan Lines AI Platform — Environment Variables
# IntegraMind AI × Minoan Lines S.A.
# ============================================================
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── DeepSeek AI ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Supabase (Cloud) ─────────────────────────────────────────────────────────
# Found in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service-role-key-here

# ── AIS Vessel Tracking ──────────────────────────────────────────────────────
AIS_API_KEY=your-aisstream-or-marinetraffic-key-here
AIS_API_URL=https://api.aisstream.io/v0

# ── Slack Alerts ─────────────────────────────────────────────────────────────
# Vessel delay alerts triggered when delay_probability > 70%
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Email (aiosmtplib) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@integramindai.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Minoan AI Platform <notifications@integramindai.com>

# ── Report Recipients ────────────────────────────────────────────────────────
COMPLIANCE_REPORT_RECIPIENT=michalis.orfanoudakis@minoan.gr
HELPDESK_DIGEST_RECIPIENT=michalis.orfanoudakis@minoan.gr

# ── App Settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://minoan-platform.vercel.app

# ── Flutter Web (dart-define — set in flutter build command, NOT here) ────────
# --dart-define=SUPABASE_URL=https://your-project-ref.supabase.co
# --dart-define=API_BASE_URL=https://minoan-api.railway.app
# AIS vessel tracking — free at aisstream.io
AISSTREAM_API_KEY=your_aisstream_api_key

# Optional: override Minoan MMSI map (format: MMSI:Name,MMSI:Name,...)
# AISSTREAM_MMSI=237902000:Knossos Palace,237927000:Festos Palace
